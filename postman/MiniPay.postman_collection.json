        {
          "name": "Delete User — GDPR Erasure (JWT required)",
          "request": {
            "method": "DELETE",
            "url": "{{user_url}}/users/{{user_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{pqc_token}}" }
            ],
            "description": "Soft-delete cu GDPR Art.17 (dreptul la stergere).\n\nNu sterge fizic inregistrarea — seteaza:\n- status = DELETED\n- firstName = [deleted]\n- lastName = [deleted]\n- email = deleted-{id}@minipay.ro\n- passwordHash = empty\n\nAstfel istoricul tranzactiilor ramane consistent."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('No Content 204', () => pm.response.to.have.status(204));",
                  "console.log('User soft-deleted (GDPR erasure). userId =', pm.collectionVariables.get('user_id'));"
                ]
              }
            }
          ]
        },

        {
          "name": "Get User dupa Delete (status DELETED)",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/users/{{user_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{pqc_token}}" }
            ],
            "description": "Dupa stergere, userul exista in MiniDS dar cu status=DELETED si datele PII sterse."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (soft deleted)', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status DELETED', () => pm.expect(json.status).to.eql('DELETED'));",
                  "pm.test('PII sters - firstName', () => pm.expect(json.firstName).to.eql('[deleted]'));",
                  "pm.test('PII sters - lastName', () => pm.expect(json.lastName).to.eql('[deleted]'));"
                ]
              }
            }
          ]
        }

