        {
          "name": "Get User by ID (JWT required)",
          "request": {
            "method": "GET",
            "url": "{{user_url}}/users/{{user_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{pqc_token}}", "description": "Ruleaza 'Issue PQC Token' mai intai" }
            ],
            "description": "Returneaza profilul userului. Necesita JWT valid in header.\n\nuser_id e salvat automat de 'Register User'.\npqc_token e salvat automat de 'Issue PQC Token'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('userId matches', () => {",
                  "    pm.expect(json.userId).to.eql(pm.collectionVariables.get('user_id'));",
                  "});",
                  "pm.test('Email prezent', () => pm.expect(json).to.have.property('email'));",
                  "pm.test('Status ACTIVE', () => pm.expect(json.status).to.eql('ACTIVE'));",
                  "pm.test('Fara passwordHash', () => pm.expect(json).to.not.have.property('passwordHash'));"
                ]
              }
            }
