                  "pm.test('Are txnId', () => pm.expect(body.txnId).to.be.a('string'));",
                  "pm.test('DPAN != PAN original', () => pm.expect(body.dpan).to.not.eql('4111111111111111'));",
                  "pm.test('Fraud score < 0.8', () => pm.expect(body.fraudScore).to.be.below(0.8));",
                  "pm.collectionVariables.set('txnId', body.txnId);",
                  "pm.collectionVariables.set('dpan', body.dpan);",
                  "console.log('txnId:', body.txnId);"
                ]
