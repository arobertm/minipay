{
  "info": {
    "name": "MiniPay E2E — api-minipay.online",
    "description": "Colecție completă E2E pentru platforma MiniPay. Acoperă autentificare OAuth2 + PQC Dilithium3, plăți (authorize/capture/refund), fraud XGBoost+SHAP, vault AES-256-GCM, 3DS2, audit Merkle, settlement, PSD2, notificări.\n\nSetup: rulează '🔐 Auth / Get Token' primul — toate celelalte request-uri folosesc {{token}} din variabilele de colecție.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "https://api-minipay.online", "type": "string" },
    { "key": "token",      "value": "", "type": "string" },
    { "key": "txnId",      "value": "", "type": "string" },
    { "key": "dpan",       "value": "", "type": "string" },
    { "key": "consentId",  "value": "", "type": "string" },
    { "key": "acsTransID", "value": "", "type": "string" },
    { "key": "pqcToken",   "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Get Token (client_credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has access_token', () => pm.expect(body.access_token).to.be.a('string'));",
                  "pm.test('Token type is bearer', () => pm.expect(body.token_type.toLowerCase()).to.eql('bearer'));",
                  "pm.collectionVariables.set('token', body.access_token);",
                  "console.log('✅ Token salvat în variabila de colecție');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "demo-client" },
                { "key": "password", "value": "demo-secret" }
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials" },
                { "key": "scope",      "value": "payments:read payments:write" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/auth/oauth2/token", "host": ["{{baseUrl}}"], "path": ["auth","oauth2","token"] }
          }
        },
        {
          "name": "Get JWKS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const keys = pm.response.json().keys;",
                  "pm.test('At least 1 key', () => pm.expect(keys.length).to.be.gte(1));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/oauth2/jwks", "host": ["{{baseUrl}}"], "path": ["auth","oauth2","jwks"] }
          }
        },
        {
          "name": "Get PQC Token (Dilithium3)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Algorithm is DILITHIUM3', () => pm.expect(body.algorithm).to.eql('DILITHIUM3'));",
                  "pm.test('NIST Level 3', () => pm.expect(body.nist_level).to.eql(3));",
                  "pm.test('Has access_token', () => pm.expect(body.access_token).to.be.a('string'));",
                  "pm.collectionVariables.set('pqcToken', body.access_token);",
                  "",
                  "// Verifică dimensiunea semnăturii Dilithium3",
                  "const parts = body.access_token.split('.');",
                  "const sigLen = Math.floor(parts[2].length * 3 / 4);",
                  "pm.test('Semnătură ~3309 bytes (NIST FIPS 204)', () => pm.expect(sigLen).to.be.closeTo(3309, 20));",
                  "console.log('Dimensiune semnătură Dilithium3:', sigLen, 'bytes');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/auth/token/pqc?subject=postman-test&audience=minipay&scope=payments:read&ttl=3600",
              "host": ["{{baseUrl}}"],
              "path": ["auth","auth","token","pqc"],
              "query": [
                { "key": "subject",  "value": "postman-test" },
                { "key": "audience", "value": "minipay" },
                { "key": "scope",    "value": "payments:read" },
                { "key": "ttl",      "value": "3600" }
              ]
            }
          }
        },
        {
          "name": "Verify PQC Token (valid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('valid = true', () => pm.expect(pm.response.json().valid).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/auth/token/pqc/verify?token={{pqcToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth","auth","token","pqc","verify"],
              "query": [{ "key": "token", "value": "{{pqcToken}}" }]
            }
          }
        },
        {
          "name": "Verify PQC Token (tampered — trebuie respins)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Manipulează payload-ul tokenului PQC",
                  "const token = pm.collectionVariables.get('pqcToken');",
                  "if (!token) { console.warn('pqcToken gol — rulează Get PQC Token primul'); return; }",
                  "const parts = token.split('.');",
                  "let payload = JSON.parse(atob(parts[1].replace(/-/g,'+').replace(/_/g,'/')));",
                  "payload.sub = 'attacker';",
                  "const tamperedPayload = btoa(JSON.stringify(payload)).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                  "pm.variables.set('tamperedToken', parts[0] + '.' + tamperedPayload + '.' + parts[2]);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('valid = false (tampered payload respins)', () => pm.expect(pm.response.json().valid).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/auth/token/pqc/verify?token={{tamperedToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth","auth","token","pqc","verify"],
              "query": [{ "key": "token", "value": "{{tamperedToken}}" }]
            }
          }
        },
        {
          "name": "Reject invalid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "bad-client" },
                { "key": "password", "value": "bad-secret" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "grant_type", "value": "client_credentials" }]
            },
            "url": { "raw": "{{baseUrl}}/auth/oauth2/token", "host": ["{{baseUrl}}"], "path": ["auth","oauth2","token"] }
          }
        }
      ]
    },
    {
      "name": "💳 Payments — Happy Path",
      "item": [
        {
          "name": "1. Authorize (Visa aprobat)",
          "event": [
